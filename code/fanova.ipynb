import numpy as np
import matplotlib.pyplot as plt
from sklearn.ensemble import RandomForestRegressor, RandomForestClassifier
from sklearn.svm import SVC
from sklearn.datasets import load_breast_cancer, load_iris, load_wine, load_digits, load_diabetes
from sklearn.model_selection import cross_val_score
import warnings
import time
warnings.filterwarnings('ignore')

def load_datasets():
    datasets = {
        'Breast Cancer': load_breast_cancer(),
        'Iris': load_iris(),

        'Digits': load_digits()
    }
    diabetes = load_diabetes()
    diabetes.target = (diabetes.target > np.median(diabetes.target)).astype(int)
    datasets['Diabetes'] = diabetes
    return datasets

def collect_svm_data(dataset, n_configs=15):
    np.random.seed(42)

    param_names = ['C', 'gamma', 'kernel', 'degree', 'coef0']
    X = []
    y = []

    for i in range(n_configs):
        # Генерация конфигураций из диапазонов статьи
        config = {
            'C': np.random.uniform(1e-3, 500),           
            'gamma': np.random.uniform(1e-3, 1.01),     
            'kernel': np.random.choice(['rbf', 'poly']),
            'degree': np.random.randint(2, 4),           
            'coef0': np.random.uniform(0, 10)            
        }

        kernel_val = 1 if config['kernel'] == 'rbf' else 0
        log_C = np.log10(config['C'] + 1e-10)
        log_gamma = np.log10(config['gamma'] + 1e-10)

        X_row = [log_C, log_gamma, kernel_val, config['degree'], config['coef0']]

        try:
            model = SVC(**config)
            scores = cross_val_score(model, dataset.data[:200], dataset.target[:200],
                                    cv=2, scoring='accuracy')
            accuracy = np.mean(scores)
        except:
            accuracy = 0.5

        X.append(X_row)
        y.append(accuracy)

    return np.array(X), np.array(y), param_names

def collect_rf_data(dataset, n_configs=15):
    np.random.seed(42)

    param_names = ['imputation', 'min_samples_split', 'split_criterion',
                   'max_features', 'min_samples_leaf', 'bootstrap']
    X = []
    y = []

    imputation_map = {'mean': 0, 'median': 1, 'mode': 2}
    criterion_map = {'gini': 0, 'entropy': 1}

    for i in range(n_configs):
        imputation = np.random.choice(['mean', 'median', 'mode'])
        min_samples_split = np.random.randint(2, 21)     
        criterion = np.random.choice(['gini', 'entropy'])
        max_features = np.random.uniform(0.1, 0.9)      
        min_samples_leaf = np.random.randint(1, 21)   
        bootstrap = np.random.choice([True, False])

        config = {
            'n_estimators': 50,  # фиксируем для стабильности
            'min_samples_split': min_samples_split,
            'min_samples_leaf': min_samples_leaf,
            'max_features': max_features,
            'bootstrap': bootstrap,
            'criterion': criterion,
            'random_state': 42
        }

        X_row = [
            imputation_map[imputation] / 2,             
            (min_samples_split - 2) / 18,               
            criterion_map[criterion],
            max_features,
            (min_samples_leaf - 1) / 19,               
            1 if bootstrap else 0
        ]

        try:
            model = RandomForestClassifier(**config)
            scores = cross_val_score(model, dataset.data[:200], dataset.target[:200],
                                    cv=2, scoring='accuracy')
            accuracy = np.mean(scores)
        except:
            accuracy = 0.5

        X.append(X_row)
        y.append(accuracy)

    return np.array(X), np.array(y), param_names

def fanova_analysis(X, y, param_names):
    rf = RandomForestRegressor(n_estimators=30, max_depth=3, random_state=42)
    rf.fit(X, y)

    importance = rf.feature_importances_
    importance_norm = importance / importance.sum()

    return importance_norm, rf.score(X, y)

def plot_violin_figure1(all_importance, classifier_name, param_names):
    fig, ax = plt.subplots(figsize=(8, 5))

    param_data = []
    for param in param_names:
        values = [all_importance[ds_name][param] for ds_name in all_importance.keys()]
        param_data.append(values)

    positions = range(len(param_names))
    parts = ax.violinplot(param_data, positions=positions,
                          showmeans=True, showmedians=True,
                          widths=0.7)

    colors = plt.cm.Set3(np.linspace(0, 1, len(param_names)))
    for i, pc in enumerate(parts['bodies']):
        pc.set_facecolor(colors[i])
        pc.set_alpha(0.7)

    parts['cmeans'].set_color('red')
    parts['cmeans'].set_linewidth(2)
    parts['cmedians'].set_color('darkred')
    parts['cmedians'].set_linewidth(2)

    ax.set_xticks(positions)
    ax.set_xticklabels(param_names, rotation=45, ha='right')
    ax.set_ylabel('Importance (Variance Contribution)')
    ax.set_title(f'{classifier_name}: Hyperparameter Importance Distribution\n')
    ax.set_ylim(0, 1)
    ax.grid(True, alpha=0.3, axis='y')

    all_values = [v for vals in param_data for v in vals]
    ax.axhline(y=np.mean(all_values), color='green', linestyle='--', alpha=0.5,
               label=f'Overall mean: {np.mean(all_values):.2f}')
    ax.legend()

    plt.tight_layout()
    plt.show()

def plot_bar_plots(all_importance, classifier_name, param_names):
    dataset_names = list(all_importance.keys())
    n_datasets = len(dataset_names)

    fig, axes = plt.subplots(2, 2, figsize=(12, 10))
    axes = axes.flatten()

    for idx, ds_name in enumerate(dataset_names):
        ax = axes[idx]
        importance = [all_importance[ds_name][param] for param in param_names]
        
        sorted_idx = np.argsort(importance)[::-1]
        sorted_names = [param_names[i] for i in sorted_idx]
        sorted_imp = [importance[i] for i in sorted_idx]

        colors = plt.cm.RdYlGn_r(np.linspace(0.2, 0.8, len(sorted_names)))
        bars = ax.bar(range(len(sorted_names)), sorted_imp, color=colors)
        ax.set_xticks(range(len(sorted_names)))
        ax.set_xticklabels(sorted_names, rotation=45, ha='right')
        ax.set_ylabel('Importance')
        ax.set_title(ds_name)
        ax.set_ylim(0, 1)

        for bar, val in zip(bars, sorted_imp):
            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,
                   f'{val:.2f}', ha='center', va='bottom', fontsize=9)

        ax.axhline(y=sorted_imp[0], color='red', linestyle='--', alpha=0.5)

    plt.suptitle(f'{classifier_name}: Parameter Importance Across Datasets\n',
                 fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.show()

def run_analysis():
    start_time = time.time()

    print("\n" + "="*80)
    print("fANOVA АНАЛИЗ")
    print("Параметры из статьи Table 2")
    print("="*80)

    # Загружаем датасеты
    datasets = load_datasets()
    print(f"\nЗАГРУЖЕНО {len(datasets)} ДАТАСЕТОВ:")
    for name, ds in datasets.items():
        print(f"   - {name}: {ds.data.shape[0]} образцов, {ds.data.shape[1]} признаков")

    svm_results = {}
    rf_results = {}

    print("\n" + "="*80)
    print("КЛАССИФИКАТОР 1: SVM")
    print("Параметры (из Table 2): C, gamma, kernel, degree, coef0")
    print("="*80)

    svm_params = ['C', 'gamma', 'kernel', 'degree', 'coef0']

    for name, dataset in datasets.items():
        print(f"\n{name}...", end=' ')

        X, y, _ = collect_svm_data(dataset, n_configs=15)
        importance, r2 = fanova_analysis(X, y, svm_params)

        svm_results[name] = {param: importance[i] for i, param in enumerate(svm_params)}

        print(f"R²={r2:.2f}")
        sorted_imp = sorted(svm_results[name].items(), key=lambda x: x[1], reverse=True)
        print(f"   Топ-3 важных параметра:")
        for param, imp in sorted_imp[:3]:
            bar = '█' * int(imp * 30)
            print(f"      {param:8}: {imp:.3f} ({imp*100:.0f}%) {bar}")

    print("\n" + "="*80)
    print("КЛАССИФИКАТОР 2: Random Forest")
    print("Параметры (из Table 2): imputation, min_samples_split, split_criterion, max_features, min_samples_leaf, bootstrap")
    print("="*80)

    rf_params = ['imputation', 'min_samples_split', 'split_criterion',
                 'max_features', 'min_samples_leaf', 'bootstrap']

    for name, dataset in datasets.items():
        print(f"\n{name}...", end=' ')

        X, y, _ = collect_rf_data(dataset, n_configs=15)
        importance, r2 = fanova_analysis(X, y, rf_params)

        rf_results[name] = {param: importance[i] for i, param in enumerate(rf_params)}

        print(f"R²={r2:.2f}")
        sorted_imp = sorted(rf_results[name].items(), key=lambda x: x[1], reverse=True)
        print(f"   Топ-3 важных параметра:")
        for param, imp in sorted_imp[:3]:
            bar = '█' * int(imp * 30)
            print(f"      {param:18}: {imp:.3f} ({imp*100:.0f}%) {bar}")

    print("\n" + "="*80)
    print("VIOLIN PLOTS (как в статье Figure 1)")
    print("="*80)

    plot_violin_figure1(svm_results, 'SVM', svm_params)
    plot_violin_figure1(rf_results, 'Random Forest', rf_params)

    print("\n" + "="*80)
    print("BAR PLOTS (сравнение по датасетам)")
    print("="*80)

    plot_bar_plots(svm_results, 'SVM', svm_params)
    plot_bar_plots(rf_results, 'Random Forest', rf_params)

    # ===== ТАБЛИЦА РЕЗУЛЬТАТОВ =====
    print("\n" + "="*80)
    print("ИТОГОВАЯ ТАБЛИЦА ВАЖНОСТИ ПАРАМЕТРОВ")
    print("="*80)

    # SVM таблица
    print("\nSVM (параметры из Table 2):")
    print(f"{'Параметр':<12}", end='')
    for name in datasets.keys():
        short_name = name[:10]
        print(f"{short_name:>12}", end='')
    print(f"{'Среднее':>10}")
    print("-" * 75)

    svm_avg = {}
    for param in svm_params:
        print(f"{param:<12}", end='')
        values = []
        for name in datasets.keys():
            val = svm_results[name][param]
            values.append(val)
            print(f"{val:>12.3f}", end='')
        avg = np.mean(values)
        svm_avg[param] = avg
        print(f"{avg:>10.3f}")

    print("\nRandom Forest (параметры из Table 2):")
    print(f"{'Параметр':<18}", end='')
    for name in datasets.keys():
        short_name = name[:10]
        print(f"{short_name:>12}", end='')
    print(f"{'Среднее':>10}")
    print("-" * 80)

    rf_avg = {}
    for param in rf_params:
        print(f"{param:<18}", end='')
        values = []
        for name in datasets.keys():
            val = rf_results[name][param]
            values.append(val)
            print(f"{val:>12.3f}", end='')
        avg = np.mean(values)
        rf_avg[param] = avg
        print(f"{avg:>10.3f}")

    print("\n" + "="*80)
    print("РЕКОМЕНДАЦИИ ДЛЯ ОПТИМИЗАЦИИ")
    print("="*80)

    print("\nSVM:")
    svm_sorted = sorted(svm_avg.items(), key=lambda x: x[1], reverse=True)
    print("   Настраивать В ПЕРВУЮ ОЧЕРЕДЬ:")
    for i, (param, avg) in enumerate(svm_sorted[:2], 1):
        print(f"      {i}. {param}: {avg:.3f} ({avg*100:.0f}%)")
    print("   Настраивать ВО ВТОРУЮ ОЧЕРЕДЬ:")
    for i, (param, avg) in enumerate(svm_sorted[2:4], 1):
        print(f"      {i}. {param}: {avg:.3f} ({avg*100:.0f}%)")

    print("\nRandom Forest:")
    rf_sorted = sorted(rf_avg.items(), key=lambda x: x[1], reverse=True)
    print("   Настраивать В ПЕРВУЮ ОЧЕРЕДЬ:")
    for i, (param, avg) in enumerate(rf_sorted[:2], 1):
        print(f"      {i}. {param}: {avg:.3f} ({avg*100:.0f}%)")
    print("   Настраивать ВО ВТОРУЮ ОЧЕРЕДЬ:")
    for i, (param, avg) in enumerate(rf_sorted[2:4], 1):
        print(f"      {i}. {param}: {avg:.3f} ({avg*100:.0f}%)")

    elapsed = time.time() - start_time
    print(f"\nВРЕМЯ ВЫПОЛНЕНИЯ: {elapsed:.1f} секунд")

    print("\n" + "="*80)
    print("АНАЛИЗ ЗАВЕРШЕН!")
    print("   Результаты показывают, какие параметры настраивать в первую очередь")
    print("   Это знание используется для Meta-Guided Bayesian Optimization")
    print("="*80)

    return svm_results, rf_results

if __name__ == "__main__":
    svm_results, rf_results = run_analysis()
