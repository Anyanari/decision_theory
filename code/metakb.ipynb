import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.ensemble import RandomForestClassifier
from sklearn.svm import SVC
from sklearn.datasets import load_breast_cancer, load_iris, load_digits, load_diabetes
from sklearn.model_selection import cross_val_score
import warnings
import time
warnings.filterwarnings('ignore')


def get_dataset_features(dataset, name):
    X = dataset.data
    y = dataset.target

    unique_classes = np.unique(y)
    n_classes = len(unique_classes)

    if n_classes > 1:
        class_counts = np.bincount(y.astype(int))
        imbalance = np.max(class_counts) / np.min(class_counts)
    else:
        imbalance = 1.0

    features = {
        'name': name,
        'n_samples': X.shape[0],
        'n_features': X.shape[1],
        'n_classes': n_classes,
        'imbalance': imbalance,
    }

    return features


class SimpleMetaKB:
    def __init__(self):
        self.hp_importance = {
            'SVM': {
                'kernel': 0.53,
                'C': 0.20,
                'gamma': 0.17,
                'coef0': 0.07,
                'degree': 0.03
            },
            'RandomForest': {
                'max_features': 0.39,
                'min_samples_leaf': 0.27,
                'bootstrap': 0.13,
                'min_samples_split': 0.09,
                'split_criterion': 0.07,
                'imputation': 0.05
            }
        }

        self.datasets = []
        self.best_configs = {}

    def add_dataset(self, dataset, name):
        features = get_dataset_features(dataset, name)
        self.datasets.append(features)

        print(f"\n   Поиск лучших конфигураций для {name}...")

        best_configs = {}

        best_svm = self._find_best_svm(dataset)
        if best_svm:
            best_configs['SVM'] = best_svm
            print(f"      SVM best accuracy: {best_svm['accuracy']:.3f}")

        best_rf = self._find_best_rf(dataset)
        if best_rf:
            best_configs['RandomForest'] = best_rf
            print(f"      RF best accuracy: {best_rf['accuracy']:.3f}")

        self.best_configs[name] = best_configs

        return features

    def _find_best_svm(self, dataset, n_trials=10):
        best_acc = 0
        best_config = None

        n_samples = min(200, len(dataset.data))
        X = dataset.data[:n_samples]
        y = dataset.target[:n_samples]

        for _ in range(n_trials):
            config = {
                'C': np.random.uniform(0.1, 100),
                'gamma': np.random.uniform(0.001, 10),
                'kernel': np.random.choice(['rbf', 'linear'])
            }

            try:
                model = SVC(**config)
                scores = cross_val_score(model, X, y, cv=3, scoring='accuracy')
                acc = np.mean(scores)

                if acc > best_acc:
                    best_acc = acc
                    best_config = config.copy()
                    best_config['accuracy'] = best_acc
            except:
                continue

        return best_config

    def _find_best_rf(self, dataset, n_trials=10):
        best_acc = 0
        best_config = None

        n_samples = min(200, len(dataset.data))
        X = dataset.data[:n_samples]
        y = dataset.target[:n_samples]

        for _ in range(n_trials):
            config = {
                'n_estimators': 50,
                'max_features': np.random.uniform(0.3, 0.9),
                'min_samples_split': np.random.randint(2, 10),
                'min_samples_leaf': np.random.randint(1, 10)
            }

            try:
                model = RandomForestClassifier(**config, random_state=42)
                scores = cross_val_score(model, X, y, cv=3, scoring='accuracy')
                acc = np.mean(scores)

                if acc > best_acc:
                    best_acc = acc
                    best_config = config.copy()
                    best_config['accuracy'] = best_acc
            except:
                continue

        return best_config

    def find_similar_datasets(self, new_dataset_features, k=2):
        if not self.datasets:
            return []

        similarities = []

        for ds in self.datasets:
            diff = 0
            diff += abs(new_dataset_features['n_samples'] - ds['n_samples']) / max(ds['n_samples'], 100)
            diff += abs(new_dataset_features['n_features'] - ds['n_features']) / max(ds['n_features'], 1)
            diff += abs(new_dataset_features['n_classes'] - ds['n_classes']) / max(ds['n_classes'], 1)
            diff += abs(new_dataset_features['imbalance'] - ds['imbalance']) / max(ds['imbalance'], 0.1)

            similarities.append((ds['name'], diff))

        similarities.sort(key=lambda x: x[1])

        return similarities[:k]

    def get_warm_start_config(self, dataset_name, algorithm):
        if dataset_name in self.best_configs:
            if algorithm in self.best_configs[dataset_name]:
                return self.best_configs[dataset_name][algorithm]
        return None

    def _format_value(self, val):
        if isinstance(val, float):
            return f"{val:.4f}"
        elif isinstance(val, str):
            return f"'{val}'"
        else:
            return str(val)

    def print_summary(self):
        print("\n" + "="*60)
        print("БАЗА ЗНАНИЙ (Meta-Knowledge Base)")
        print("="*60)

        print("\nДАТАСЕТЫ В БАЗЕ:")
        for ds in self.datasets:
            print(f"   - {ds['name']}: {ds['n_samples']} образцов, "
                  f"{ds['n_features']} признаков, {ds['n_classes']} классов, "
                  f"дисбаланс: {ds['imbalance']:.2f}")

        print("\nЛУЧШИЕ КОНФИГУРАЦИИ:")
        for ds_name, configs in self.best_configs.items():
            print(f"\n   {ds_name}:")
            for alg, cfg in configs.items():
                print(f"      {alg}: accuracy = {cfg['accuracy']:.3f}")
                if alg in self.hp_importance:
                    important_params = self.hp_importance[alg]
                    top_params = sorted(important_params.items(), key=lambda x: x[1], reverse=True)[:3]
                    for param, _ in top_params:
                        if param in cfg:
                            val = cfg[param]
                            print(f"         {param}: {self._format_value(val)}")

        print("\nВАЖНОСТЬ ПАРАМЕТРОВ (из fANOVA):")
        for alg, params in self.hp_importance.items():
            print(f"\n   {alg}:")
            sorted_params = sorted(params.items(), key=lambda x: x[1], reverse=True)
            for param, imp in sorted_params[:4]:
                print(f"      {param}: {imp:.3f} ({imp*100:.0f}%)")


def plot_similar_datasets(kb, new_features, similar_datasets):
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))

    ax1 = axes[0]

    metrics = ['n_samples', 'n_features', 'n_classes', 'imbalance']
    labels = ['Образцы', 'Признаки', 'Классы', 'Дисбаланс']

    x = np.arange(len(metrics))
    width = 0.25

    new_vals = [new_features[m] for m in metrics]
    ax1.bar(x - width, new_vals, width, label='Новый датасет', color='blue', alpha=0.7)

    colors = ['green', 'orange']
    for i, (ds_name, _) in enumerate(similar_datasets[:2]):
        ds = next((d for d in kb.datasets if d['name'] == ds_name), None)
        if ds:
            vals = [ds[m] for m in metrics]
            ax1.bar(x + (i * width), vals, width, label=f'Похожий: {ds_name}',
                   color=colors[i % len(colors)], alpha=0.7)

    ax1.set_xticks(x)
    ax1.set_xticklabels(labels)
    ax1.set_ylabel('Значение')
    ax1.set_title('Сравнение мета-признаков датасетов')
    ax1.legend()
    ax1.grid(True, alpha=0.3)

    ax2 = axes[1]

    svm_imp = kb.hp_importance['SVM']
    rf_imp = kb.hp_importance['RandomForest']

    x2 = np.arange(len(svm_imp))
    width2 = 0.35

    ax2.bar(x2 - width2/2, list(svm_imp.values()), width2, label='SVM',
           color='blue', alpha=0.7)
    ax2.bar(x2 + width2/2, list(rf_imp.values())[:len(svm_imp)], width2,
           label='Random Forest', color='orange', alpha=0.7)

    ax2.set_xticks(x2)
    ax2.set_xticklabels(list(svm_imp.keys()), rotation=45)
    ax2.set_ylabel('Важность')
    ax2.set_title('Важность параметров (результаты fANOVA)')
    ax2.legend()
    ax2.grid(True, alpha=0.3)

    plt.tight_layout()
    plt.show()


def run_metakb():
    start_time = time.time()

    print("\n" + "="*70)
    print("🔨 АЛГОРИТМ 2: Построение базы знаний (Meta-Knowledge Base)")
    print("="*70)

    print("\nЗагрузка датасетов...")
    datasets = {
        'Breast Cancer': load_breast_cancer(),
        'Iris': load_iris(),
        'Digits': load_digits(),
        'Diabetes': load_diabetes()
    }

    diabetes = datasets['Diabetes']
    diabetes.target = (diabetes.target > np.median(diabetes.target)).astype(int)

    kb = SimpleMetaKB()

    print("\nПоиск лучших конфигураций для каждого датасета...")
    for name, dataset in datasets.items():
        print(f"\n   Обработка: {name}")
        kb.add_dataset(dataset, name)

    kb.print_summary()

    print("\n" + "="*70)
    print("ДЕМОНСТРАЦИЯ: Поиск похожих датасетов")
    print("="*70)
    
    test_features = {
        'name': 'Test Dataset',
        'n_samples': 500,
        'n_features': 25,
        'n_classes': 3,
        'imbalance': 1.2
    }

    print(f"\nТестовый датасет:")
    print(f"   - Образцов: {test_features['n_samples']}")
    print(f"   - Признаков: {test_features['n_features']}")
    print(f"   - Классов: {test_features['n_classes']}")
    print(f"   - Дисбаланс: {test_features['imbalance']:.2f}")

    similar = kb.find_similar_datasets(test_features, k=2)

    print(f"\nНайдены похожие датасеты:")
    for ds_name, diff in similar:
        print(f"   - {ds_name} (разница: {diff:.2f})")

    print(f"\nWarm-start конфигурации (для начала оптимизации):")
    for ds_name, _ in similar:
        for alg in ['SVM', 'RandomForest']:
            config = kb.get_warm_start_config(ds_name, alg)
            if config:
                print(f"\n   Из датасета {ds_name} для {alg}:")
                print(f"      accuracy: {config['accuracy']:.3f}")
                if alg in kb.hp_importance:
                    important_params = kb.hp_importance[alg]
                    top_params = sorted(important_params.items(), key=lambda x: x[1], reverse=True)[:3]
                    for param, _ in top_params:
                        if param in config:
                            val = config[param]
                            if isinstance(val, float):
                                print(f"      {param}: {val:.4f}")
                            else:
                                print(f"      {param}: {val}")

    print("\nВизуализация...")
    plot_similar_datasets(kb, test_features, similar)

    elapsed = time.time() - start_time
    print(f"\nВРЕМЯ ВЫПОЛНЕНИЯ: {elapsed:.1f} секунд")

    print("\n" + "="*70)
    print("АЛГОРИТМ 2 ЗАВЕРШЕН!")
    print("   База знаний готова для использования в MGBO")
    print("="*70)

    return kb


if __name__ == "__main__":
    kb = run_metakb()
